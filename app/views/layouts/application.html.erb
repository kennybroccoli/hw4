<!DOCTYPE html>
<html>
  <head>
    <title>Tacostagram Final</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="/stylesheets/application.css">
  </head>

  <body>
    <nav class="navbar navbar-expand-lg bg-primary mb-3" data-bs-theme="dark">
      <div class="container-fluid">
        <a class="navbar-brand" href="/">ENTR-451</a>
        <div class="navbar-nav">
          <a class="nav-link" href="/">Home</a>
          <% if @current_user %>
            <span class="navbar-text mx-2">Logged in as: <%= @current_user["username"] %></span>
            <a class="nav-link" href="/logout">Logout</a>
          <% else %>
            <a class="nav-link" href="/login">Login</a>
            <a class="nav-link" href="/users/new">Signup</a>
          <% end %>
        </div>
      </div>
    </nav>

    <div class="container">
      <%= flash["notice"] %>

      <%= yield %>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>